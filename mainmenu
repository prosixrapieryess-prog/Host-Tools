#!/bin/bash

# ═══════════════════════════════════════════════════════════════
#   COLORS & STYLES
# ═══════════════════════════════════════════════════════════════
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BRIGHT_RED='\033[1;31m'
BRIGHT_GREEN='\033[1;32m'
BRIGHT_YELLOW='\033[1;33m'
BRIGHT_BLUE='\033[1;34m'
BRIGHT_CYAN='\033[1;36m'
BRIGHT_MAGENTA='\033[1;35m'
DARK_GRAY='\033[1;30m'
NC='\033[0m'
BD='\033[1m'
DIM='\033[2m'

# ═══════════════════════════════════════════════════════════════
#   HOLOGRAM BANNER WITH FLICKER
# ═══════════════════════════════════════════════════════════════
display_header() {
    clear



    # Final gradient render
    echo -e "${BRIGHT_BLUE}${BD}"
    echo '   ██████╗ ██████╗  ██████╗ ██╗  ██╗██╗     ███████╗ ██████╗ ███████╗███╗  ██╗██████╗ ██╗   ██╗████████╗
    echo '   ██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝██║     ██╔════╝██╔════╝ ██╔════╝████╗ ██║██╔══██╗╚██╗ ██╔╝╚══██╔══╝
    echo '   ██████╔╝██████╔╝██║   ██║ ╚███╔╝ ██║     █████╗  ██║  ███╗█████╗  ██╔██╗██║██║  ██║ ╚████╔╝    ██║   
    echo '   ██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗ ██║     ██╔══╝  ██║   ██║██╔══╝  ██║╚████║██║  ██║  ╚██╔╝     ██║   
    echo '   ██║     ██║  ██║╚██████╔╝██╔╝ ██╗███████╗███████╗╚██████╔╝███████╗██║ ╚███║██████╔╝   ██║      ██║   
    echo '   ╚═╝     ╚═╝  ╚═╝ ╚═════╝╚═╝   ╚═╝╚══════╝╚══════╝ ╚═════╝ ╚══════╝╚═╝  ╚══╝╚═════╝    ╚═╝      ╚═╝   
    echo -e "${NC}"

    # Hologram scanline effect
    echo -e "   ${BRIGHT_CYAN}▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔${NC}"
    echo ""

    # System info bar
    local host_color="${BRIGHT_GREEN}"
    local user_color="${BRIGHT_YELLOW}"
    echo -e "   ${DARK_GRAY}╔══════════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "   ${DARK_GRAY}║${NC}  ⚡ ${BRIGHT_YELLOW}${BD}SERVER UTILITIES & TOOLS${NC}  ${DARK_GRAY}│${NC}  🖥  Host: ${host_color}${BD}$(hostname)${NC}  ${DARK_GRAY}│${NC}  👤 User: ${user_color}${BD}$(whoami)${NC}   ${DARK_GRAY}║${NC}"
    echo -e "   ${DARK_GRAY}╚══════════════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════
#   MENU RENDERER
# ═══════════════════════════════════════════════════════════════
display_menu() {
    # Section: Access & Network
    echo -e "   ${BRIGHT_MAGENTA}┌─────────────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "   ${BRIGHT_MAGENTA}│${NC}  ${BRIGHT_CYAN}${BD}🔐  ACCESS & NETWORK${NC}                                                     ${BRIGHT_MAGENTA}│${NC}"
    echo -e "   ${BRIGHT_MAGENTA}├─────────────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "   ${BRIGHT_MAGENTA}│${NC}   ${BRIGHT_YELLOW}${BD}1)${NC}  ${WHITE}Root Access${NC}           ${DIM}— Set or reset root password${NC}               ${BRIGHT_MAGENTA}│${NC}"
    echo -e "   ${BRIGHT_MAGENTA}│${NC}   ${BRIGHT_YELLOW}${BD}2)${NC}  ${WHITE}Tailscale${NC}             ${DIM}— Install & connect Tailscale VPN${NC}           ${BRIGHT_MAGENTA}│${NC}"
    echo -e "   ${BRIGHT_MAGENTA}│${NC}   ${BRIGHT_YELLOW}${BD}3)${NC}  ${WHITE}ZeroTier${NC}              ${DIM}— Install & join ZeroTier network${NC}           ${BRIGHT_MAGENTA}│${NC}"
    echo -e "   ${BRIGHT_MAGENTA}└─────────────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # Section: System Operations
    echo -e "   ${BRIGHT_BLUE}┌─────────────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "   ${BRIGHT_BLUE}│${NC}  ${BRIGHT_CYAN}${BD}⚙️   SYSTEM OPERATIONS${NC}                                                   ${BRIGHT_BLUE}│${NC}"
    echo -e "   ${BRIGHT_BLUE}├─────────────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "   ${BRIGHT_BLUE}│${NC}   ${BRIGHT_YELLOW}${BD}4)${NC}  ${WHITE}System Info${NC}            ${DIM}— Kernel, RAM, Disk usage${NC}                   ${BRIGHT_BLUE}│${NC}"
    echo -e "   ${BRIGHT_BLUE}│${NC}   ${BRIGHT_YELLOW}${BD}5)${NC}  ${WHITE}Port Forward${NC}           ${DIM}— SSH tunnel port forwarding${NC}                ${BRIGHT_BLUE}│${NC}"
    echo -e "   ${BRIGHT_BLUE}└─────────────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # Section: GUI & Terminal
    echo -e "   ${BRIGHT_GREEN}┌─────────────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "   ${BRIGHT_GREEN}│${NC}  ${BRIGHT_CYAN}${BD}🖥  GUI & TERMINAL${NC}                                                       ${BRIGHT_GREEN}│${NC}"
    echo -e "   ${BRIGHT_GREEN}├─────────────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "   ${BRIGHT_GREEN}│${NC}   ${BRIGHT_YELLOW}${BD}6)${NC}  ${WHITE}Web Terminal${NC}           ${DIM}— Install & launch ttyd on port 8080${NC}        ${BRIGHT_GREEN}│${NC}"
    echo -e "   ${BRIGHT_GREEN}│${NC}   ${BRIGHT_YELLOW}${BD}7)${NC}  ${WHITE}RDP Installer${NC}          ${DIM}— Install XFCE4 + XRDP desktop${NC}             ${BRIGHT_GREEN}│${NC}"
    echo -e "   ${BRIGHT_GREEN}└─────────────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # Exit option
    echo -e "   ${DARK_GRAY}┌─────────────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "   ${DARK_GRAY}│${NC}   ${BRIGHT_RED}${BD}0)${NC}  ${RED}Exit${NC}                  ${DIM}— Quit the script${NC}                              ${DARK_GRAY}│${NC}"
    echo -e "   ${DARK_GRAY}└─────────────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    echo -ne "   ${BRIGHT_CYAN}${BD}  ➤  Select Tool ${DARK_GRAY}[0-7]${BRIGHT_CYAN} → ${NC}"
}

# ═══════════════════════════════════════════════════════════════
#   PRINT HELPERS
# ═══════════════════════════════════════════════════════════════
print_section() {
    echo ""
    echo -e "   ${BRIGHT_CYAN}╔══════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_CYAN}║${BD}${WHITE}  ⚡  $1${NC}  ${BRIGHT_CYAN}║${NC}"
    echo -e "   ${BRIGHT_CYAN}╚══════════════════════════════════════════╝${NC}"
    echo ""
}

print_ok()   { echo -e "   ${BRIGHT_GREEN}  ✔  ${GREEN}$1${NC}"; }
print_err()  { echo -e "   ${BRIGHT_RED}  ✘  ${RED}$1${NC}"; }
print_info() { echo -e "   ${BRIGHT_YELLOW}  ➤  ${YELLOW}$1${NC}"; }

pause() {
    echo ""
    echo -e "   ${DARK_GRAY}─────────────────────────────────────────────────${NC}"
    echo -ne "   ${DIM}Press ${BRIGHT_CYAN}Enter${NC}${DIM} to return to menu...${NC}"
    read
}

# ═══════════════════════════════════════════════════════════════
#   MAIN LOOP
# ═══════════════════════════════════════════════════════════════
while true; do
    display_header
    display_menu
    read option

    case $option in

        # ── Root Access ──────────────────────────────────────
        1)
            print_section "ROOT ACCESS"
            print_info "Setting root password..."
            sudo passwd root
            print_ok "Root password updated."
            pause
            ;;

        # ── Tailscale ────────────────────────────────────────
        2)
            print_section "TAILSCALE VPN"
            print_info "Downloading and installing Tailscale..."
            curl -fsSL https://tailscale.com/install.sh | sh
            print_info "Connecting to Tailscale network..."
            sudo tailscale up
            print_ok "Tailscale connected."
            pause
            ;;

        # ── ZeroTier ─────────────────────────────────────────
        3)
            print_section "ZEROTIER NETWORK"
            print_info "Installing ZeroTier..."
            curl -s https://install.zerotier.com | sudo bash
            print_ok "ZeroTier installed."
            print_info "Use: sudo zerotier-cli join <network-id>"
            pause
            ;;

        # ── System Info ──────────────────────────────────────
        4)
            print_section "SYSTEM INFORMATION"
            echo -e "   ${BRIGHT_CYAN}${BD}── Kernel ─────────────────────────────────────${NC}"
            echo -e "   ${WHITE}$(uname -a)${NC}"
            echo ""
            echo -e "   ${BRIGHT_CYAN}${BD}── Memory ─────────────────────────────────────${NC}"
            free -h | awk 'NR==1{printf "   \033[1;33m%-12s %-10s %-10s %-10s\n\033[0m",$1,$2,$3,$4} NR>1{printf "   \033[0;37m%-12s %-10s %-10s %-10s\n\033[0m",$1,$2,$3,$4}'
            echo ""
            echo -e "   ${BRIGHT_CYAN}${BD}── Disk ───────────────────────────────────────${NC}"
            df -h | awk 'NR==1{printf "   \033[1;33m%-20s %-6s %-6s %-6s %-6s\n\033[0m",$1,$2,$3,$4,$5} NR>1{printf "   \033[0;37m%-20s %-6s %-6s %-6s %-6s\n\033[0m",$1,$2,$3,$4,$5}'
            pause
            ;;

        # ── Port Forward ─────────────────────────────────────
        5)
            print_section "SSH PORT FORWARDING"
            echo -ne "   ${BRIGHT_YELLOW}  Local Port  : ${NC}"; read lp
            echo -ne "   ${BRIGHT_YELLOW}  Remote IP   : ${NC}"; read rip
            echo -ne "   ${BRIGHT_YELLOW}  Remote Port : ${NC}"; read rp
            print_info "Opening tunnel: localhost:$lp → $rip:$rp"
            ssh -L "$lp:$rip:$rp" localhost
            print_ok "Tunnel closed."
            pause
            ;;

        # ── Web Terminal ─────────────────────────────────────
        6)
            print_section "WEB TERMINAL (ttyd)"
            print_info "Updating package lists..."
            sudo apt update -qq
            print_info "Installing ttyd..."
            sudo apt install -y ttyd
            print_ok "ttyd installed. Launching on port 8080..."
            print_info "Access at: http://$(hostname -I | awk '{print $1}'):8080"
            ttyd -p 8080 bash
            pause
            ;;

        # ── RDP Installer ────────────────────────────────────
        7)
            print_section "RDP DESKTOP INSTALLER"
            print_info "Updating package lists..."
            sudo apt update -qq
            print_info "Installing XFCE4 desktop + XRDP..."
            sudo apt install -y xfce4 xfce4-goodies xrdp
            print_info "Enabling XRDP service..."
            sudo systemctl enable xrdp
            sudo systemctl start xrdp
            print_ok "XRDP is running! Connect via Remote Desktop on port 3389."
            print_info "RDP Address: $(hostname -I | awk '{print $1}'):3389"
            pause
            ;;

        # ── Exit ─────────────────────────────────────────────
        0)
            clear
            echo ""
            echo -e "   ${BRIGHT_CYAN}${BD}  ✦  Goodbye! Exiting ProxLegendYT Tools...${NC}"
            echo ""
            exit 0
            ;;

        # ── Invalid ──────────────────────────────────────────
        *)
            echo ""
            echo -e "   ${BRIGHT_RED}  ✘  Invalid option: '${option}' — please choose 0–7.${NC}"
            pause
            ;;
    esac
done
